{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "dependencyDashboard": false,
  "prCreation": "not-pending",
  "prConcurrentLimit": 5,
  "baseBranches": [
    "master"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "minor",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
